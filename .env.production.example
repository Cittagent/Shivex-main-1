# Production environment example for AWS deployments.
# Copy this file to your production secret/config store and replace all placeholders.

ENVIRONMENT=production
JWT_SECRET_KEY=replace-with-strong-random-secret
DATABASE_URL=mysql+aiomysql://USER:PASSWORD@rds-endpoint:3306/ai_factoryops
REDIS_URL=redis://elastiCache-endpoint:6379/0

# Internal service URLs
AUTH_SERVICE_BASE_URL=https://auth.internal.example.com
DEVICE_SERVICE_URL=https://device.internal.example.com
ENERGY_SERVICE_URL=https://energy.internal.example.com
REPORTING_SERVICE_URL=https://reporting.internal.example.com
RULE_ENGINE_SERVICE_BASE_URL=https://rules.internal.example.com
DATA_SERVICE_BASE_URL=https://data.internal.example.com
COPILOT_SERVICE_BASE_URL=https://copilot.internal.example.com

# InfluxDB / telemetry
INFLUXDB_URL=https://influxdb.internal.example.com:8086
INFLUXDB_TOKEN=replace-with-influx-token
INFLUXDB_ORG=energy-org
INFLUXDB_BUCKET=telemetry
INFLUXDB_MEASUREMENT=device_telemetry
INFLUXDB_RETENTION_DAYS=365

# S3 / object storage
S3_ENDPOINT_URL=https://s3.amazonaws.com
S3_BUCKET_NAME=energy-platform-datasets
MINIO_ENDPOINT=
MINIO_EXTERNAL_URL=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# Email notifications
EMAIL_ENABLED=true
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=alerts@example.com
EMAIL_SMTP_PASSWORD=replace-with-smtp-password
EMAIL_FROM_ADDRESS=alerts@example.com

# SMS notifications
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM_NUMBER=

# WhatsApp notifications
WHATSAPP_ENABLED=false
TWILIO_WHATSAPP_FROM_NUMBER=

# MQTT / device ingress
EMQX_ALLOW_ANONYMOUS=false
MQTT_BROKER_URL=mqtts://broker.example.com:8883
MQTT_USERNAME=
MQTT_PASSWORD=

# Observability and platform flags
LOG_LEVEL=INFO
DEBUG=false
